{
  "_provenance": "Template lifted from genvid-holdings/cordova-plugin-marketplace@9b6721bba942b10f95c5ca0ab02f5728b9b1c308 (ios-build.json). Diff against @main before use; see SKILL.md. SNIPPET: shows the per-repo-relevant developmentTeam substitution mechanism only. The distribute job in ios.yml writes a full build.json at runtime using the APPLE_DEVELOPMENT_TEAM secret from 1Password — this file is the smoke/debug fallback for local dev. Replace DEVELOPMENT_TEAM with your Apple team ID (10-character alphanumeric).",
  "ios": {
    "debug": {
      "codeSignIdentity": "iPhone Developer",
      "developmentTeam": "DEVELOPMENT_TEAM",
      "packageType": "development",
      "automaticProvisioning": true
    },
    "release": {
      "codeSignIdentity": "iPhone Developer",
      "developmentTeam": "DEVELOPMENT_TEAM",
      "packageType": "development",
      "automaticProvisioning": true
    }
  }
}
