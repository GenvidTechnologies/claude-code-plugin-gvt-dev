{
  "project": {
    "name": "genvid-dev",
    "description": "The genvid-dev Claude Code plugin: shared skills, agents, hooks, and conventions for Genvid game projects.",
    "languages": ["javascript"]
  },
  "commands": {
    "test": "node --test skills/audit-conventions/scripts/test/*.test.mjs",
    "lint": "",
    "build": "",
    "validate": "claude plugin validate . && node --test skills/audit-conventions/scripts/test/*.test.mjs"
  },
  "repo": {
    "default_branch": "main",
    "host": "github"
  },
  "features": {},
  "paths": {},
  "bugTracker": {
    "kind": "github",
    "actionQuery": "gh issue list --state open -L 200 --json number,title,labels,body,assignees",
    "comparisonQuery": "gh issue list --state all -L 500 --json number,title,labels,state",
    "readOne": "gh issue view {id} --json number,title,body,labels,comments",
    "triagedLabel": "triaged",
    "needsInfoLabel": "needs-info"
  }
}
